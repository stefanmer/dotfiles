#!/usr/bin/env bash

# Shell prompt based on the Solarized Dark theme.
# Screenshot: http://i.imgur.com/EkEtphC.png
# Heavily inspired by @necolas’s prompt: https://github.com/necolas/dotfiles
# iTerm → Profiles → Text → use 13pt Monaco with 1.1 vertical spacing.

# Source git’s official prompt helper (`__git_ps1`) if it isn’t already
# available. Git for Windows auto-loads it; on Linux/macOS it lives in
# git’s contrib/completion directory.
if ! type -t __git_ps1 &> /dev/null; then
	for gitPrompt in \
		/mingw64/share/git/completion/git-prompt.sh \
		/usr/share/git/completion/git-prompt.sh \
		/usr/share/git-core/contrib/completion/git-prompt.sh \
		/usr/lib/git-core/git-sh-prompt \
		/opt/homebrew/etc/bash_completion.d/git-prompt.sh \
		/usr/local/etc/bash_completion.d/git-prompt.sh \
		"${HOME}/.git-prompt.sh"; do
		if [ -r "${gitPrompt}" ]; then
			source "${gitPrompt}";
			break;
		fi;
	done;
	unset gitPrompt;
fi;

# `__git_ps1` configuration (see git-prompt.sh for the full list).
GIT_PS1_SHOWDIRTYSTATE="${GIT_PS1_SHOWDIRTYSTATE:-1}";      # `*` unstaged, `+` staged
GIT_PS1_SHOWSTASHSTATE="${GIT_PS1_SHOWSTASHSTATE:-1}";      # `$` stashed
GIT_PS1_SHOWUNTRACKEDFILES="${GIT_PS1_SHOWUNTRACKEDFILES:-1}"; # `%` untracked
GIT_PS1_SHOWUPSTREAM="${GIT_PS1_SHOWUPSTREAM:-auto}";       # `<` behind, `>` ahead, `<>` diverged, `=` in sync
GIT_PS1_SHOWCOLORHINTS="${GIT_PS1_SHOWCOLORHINTS:-1}";      # color the state flags (PROMPT_COMMAND mode only)

if [ "$(tput colors 2> /dev/null || echo 0)" -ge 256 ]; then
	tput sgr0; # reset colors
	bold=$(tput bold);
	reset=$(tput sgr0);
	# Solarized colors, taken from http://git.io/solarized-colors.
	black=$(tput setaf 0);
	blue=$(tput setaf 33);
	cyan=$(tput setaf 37);
	gray=$(tput setaf 240); # Solarized base01, for muted parts
	green=$(tput setaf 64);
	orange=$(tput setaf 166);
	purple=$(tput setaf 125);
	red=$(tput setaf 124);
	violet=$(tput setaf 61);
	white=$(tput setaf 15);
	yellow=$(tput setaf 136);
elif tput setaf 1 &> /dev/null; then
	tput sgr0; # reset colors
	bold=$(tput bold);
	reset=$(tput sgr0);
	# ANSI colors (0–7) follow the terminal’s own color scheme; Solarized’s
	# extra hues map onto their nearest ANSI or bold/bright variant, per
	# Solarized’s official 16-color assignments.
	black=$(tput setaf 0);
	blue=$(tput setaf 4);
	cyan=$(tput setaf 6);
	gray="${bold}$(tput setaf 0)"; # bright black, for muted parts
	green=$(tput setaf 2);
	orange="${bold}$(tput setaf 1)"; # bright red
	purple=$(tput setaf 5);
	red=$(tput setaf 1);
	violet="${bold}$(tput setaf 5)"; # bright magenta
	white="${bold}$(tput setaf 7)";
	yellow=$(tput setaf 3);
else
	bold='';
	reset="\e[0m";
	black="\e[1;30m";
	blue="\e[1;34m";
	cyan="\e[1;36m";
	gray="\e[1;30m";
	green="\e[1;32m";
	orange="\e[1;33m";
	purple="\e[1;35m";
	red="\e[1;31m";
	violet="\e[1;35m";
	white="\e[1;37m";
	yellow="\e[1;33m";
fi;

# Highlight the user name when logged in as root.
if [[ "${USER}" == "root" ]]; then
	userStyle="${red}";
else
	userStyle="${green}";
fi;

# Highlight the hostname when connected via SSH; on a local session it
# carries no information, so it stays quiet — cyan rather than gray only
# to set it apart from the surrounding punctuation.
if [[ "${SSH_TTY}" ]]; then
	hostStyle="${bold}${purple}";
else
	hostStyle="${cyan}";
fi;

# Prompt segment configuration. Defaults can be overridden in ~/.extra,
# or changed at runtime with the `prompt` command below.


PROMPT_SHOW_USER="${PROMPT_SHOW_USER:-1}";
PROMPT_SHOW_HOST="${PROMPT_SHOW_HOST:-1}";
PROMPT_SHOW_GIT="${PROMPT_SHOW_GIT:-0}";
PROMPT_SHOW_TIME="${PROMPT_SHOW_TIME:-1}";
PROMPT_PATH_STYLE="${PROMPT_PATH_STYLE:-full}"; # full | base | none

# Rebuild PS1 from the configuration variables. Runs before every prompt
# via PROMPT_COMMAND, so changes take effect at the next prompt.
build_prompt() {
	local exitCode=$?; # must be first: the last command’s exit status
	local sep='';

	# Keep `$` on the same line when the user and host segments are both
	# off and the path is reduced to its base name
	# (i.e. the `prompt minimal` preset: just `dirname $`).
	local newline='\n';
	if [ "${PROMPT_SHOW_USER}" != "1" ] && [ "${PROMPT_SHOW_HOST}" != "1" ] && \
		[ "${PROMPT_PATH_STYLE}" = "base" ]; then
		newline='';
	fi;

	PS1="\[\033]0;\W\007\]"; # terminal title: working directory base name
	# Skip the blank line separating prompts when the terminal is clean
	# (fresh shell, or right after `clear` — see the wrapper below).
	if [ "${PROMPT_CLEAN}" != "1" ]; then
		PS1+="\n"; # blank line between the previous output and the prompt
	fi;
	PROMPT_CLEAN=0;

	# Right-aligned time: jump to the right edge, print, and return with
	# `\r` — net zero width, so readline’s line math stays intact. Long
	# left-side content simply overwrites it. The format is a fixed
	# 12 columns wide, so the position never shifts.
	if [ "${PROMPT_SHOW_TIME}" = "1" ]; then
		PS1+="\[\033[$(( ${COLUMNS:-80} - 11 ))G${reset}${gray}\D{%H:%M %d.%m.}\r\]";
	fi;

	if [ "${PROMPT_SHOW_USER}" = "1" ]; then
		PS1+="\[${userStyle}\]\u"; # username
		sep=1;
	fi;
	if [ "${PROMPT_SHOW_HOST}" = "1" ]; then
		[ -n "${sep}" ] && PS1+="\[${gray}\]@";
		PS1+="\[${hostStyle}\]\h"; # host
		sep=1;
	fi;
	if [ "${PROMPT_PATH_STYLE}" != "none" ]; then
		[ -n "${sep}" ] && PS1+="\[${gray}\]: ";
		if [ "${PROMPT_PATH_STYLE}" = "base" ]; then
			PS1+="\[${bold}${blue}\]\W "; # working directory base name
		else
			PS1+="\[${bold}${blue}\]\w "; # working directory full path
		fi;
		sep=1;
	fi;

	# `$` turns red when the last command exited non-zero.
	local promptStyle="${white}";
	[ "${exitCode}" -ne 0 ] && promptStyle="${red}";
	local suffix="${newline}\[${reset}${promptStyle}\]\$ \[${reset}\]"; # `$` (and reset color)

	# Git segment; silently disabled when `__git_ps1` is unavailable.
	if [ "${PROMPT_SHOW_GIT}" = "1" ] && type -t __git_ps1 &> /dev/null; then
		# PROMPT_COMMAND mode: `__git_ps1 pre post fmt` assembles PS1
		# itself. This is the only mode where GIT_PS1_SHOWCOLORHINTS
		# colors the state flags.
		__git_ps1 "${PS1}" "${suffix}" "\[${reset}${gray}\](\[${orange}\]%s\[${gray}\])";
	else
		PS1+="${suffix}";
	fi;
}

# `build_prompt` must run first in PROMPT_COMMAND so it sees the last
# command’s exit status, and only once — re-sourcing this file must not
# stack another copy (a second run would always see the first’s `$?` = 0).
if [[ "; ${PROMPT_COMMAND};" != *[\;\ ]"build_prompt;"* ]]; then
	PROMPT_COMMAND="build_prompt${PROMPT_COMMAND:+; ${PROMPT_COMMAND}}";
fi;
build_prompt;
export PS1;

# The terminal starts out clean: skip the blank line before the very first
# prompt. `clear` returns the terminal to that state. Set after the eager
# `build_prompt` call above so the first PROMPT_COMMAND run consumes it.
PROMPT_CLEAN=1;
clear() {
	command clear "$@" && PROMPT_CLEAN=1;
}

PS2="\[${yellow}\]→ \[${reset}\]";
export PS2;
